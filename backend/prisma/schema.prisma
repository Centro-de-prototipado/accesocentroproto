generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             Int      @id @default(autoincrement())
  cedula         String?  @unique
  nombre         String
  huella_id      Int      @unique
  telefono       String?
  estado         String   @default("activo")
  rol            String   @default("empleado")
  fecha_registro DateTime @default(now())
  foto_url       String?

  accesos Acceso[]
}

model Dispositivo {
  id          String   @id
  nombre      String
  ubicacion   String?
  estado      String   @default("offline")
  ultimo_ping DateTime @default(now())
  ip          String?
  Acceso      Acceso[]
}

model Acceso {
  id             Int      @id @default(autoincrement())
  usuario_id     Int?
  timestamp      DateTime @default(now())
  resultado      String
  confianza      Int
  dispositivo_id String

  usuario     Usuario?    @relation(fields: [usuario_id], references: [id])
  dispositivo Dispositivo @relation(fields: [dispositivo_id], references: [id])
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  sesiones SesionAdmin[]
}

model UsuarioEliminado {
  id                Int      @id @default(autoincrement())
  cedula            String?
  nombre            String
  huella_id         Int
  telefono          String?
  fecha_eliminacion DateTime @default(now())
  motivo            String?
}

model HuellaDisponible {
  id        Int      @id @default(autoincrement())
  huella_id Int      @unique
  freed_at  DateTime @default(now())
}

model SesionAdmin {
  id         Int      @id @default(autoincrement())
  admin_id   Int
  username   String
  hora_inicio DateTime @default(now())
  ip         String?
  dispositivo String?

  admin Admin @relation(fields: [admin_id], references: [id])
}
